{
  "name": "belot",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "check-types": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "vitest watch",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:web": "pnpm --filter @belot/e2e test:e2e:web",
    "test:e2e:mobile": "pnpm --filter @belot/e2e test:e2e:mobile",
    "test:e2e:api": "pnpm --filter @belot/e2e test:e2e:api",
    "test:e2e:setup": "pnpm --filter @belot/e2e setup",
    "dev:ui": "turbo run dev --filter=@belot/mobile --filter=@belot/web",
    "nuke": "node nuke.js",
    "lockfile:sync": "pnpm install --lockfile-only",
    "lockfile:check": "pnpm install --frozen-lockfile",
    "precommit": "node scripts/pre-commit-checks.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@belot/vitest-config": "workspace:*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/coverage-v8": "catalog:",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "react": "19.1.0",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
