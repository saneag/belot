{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": []
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
